+	(match_operand:MXU2 0 "register_operand"  "q"))]
+  "ISA_HAS_MXU2"
+  "su1q\t%w0,%2(%z1)"
+  [(set_attr "lat_type" "unknown")
+   (set_attr "mode" "TI")
+   (set_attr "can_delay" "no")]
