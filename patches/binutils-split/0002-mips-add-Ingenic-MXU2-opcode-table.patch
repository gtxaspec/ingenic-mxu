From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Alfonso Gamboa <gtxent@gmail.com>
Subject: [PATCH 2/4] mips: add Ingenic MXU2 opcode table

Add operand format definitions and 364 MXU2 instruction opcodes.

The '=' prefix introduces MXU2 operand formats:
  =h/=j  MXU2 register at bit positions 6/11
  =s/=t  MXU2 register at bit positions 16/21
  =k/=l  signed immediate 15/10-bit at position 11
  =g     branch target (10-bit PC-relative at position 6, shift 2)
  =v/=w  element index (5/8-bit at position 16)
  =x     MXU2 control register
  =y     unsigned 8-bit immediate
  =L     aligned offset (10-bit at position 11, 4-byte aligned)

Instructions cover integer arithmetic, comparisons, shifts, bitwise,
floating-point, dot product, element permute, type conversions,
fixed-point multiply, and load/store operations.
---
--- a/opcodes/mips-opc.c
+++ b/opcodes/mips-opc.c
@@ -211,6 +211,25 @@
     case 'x': REG (0, 0, GP);
     case 'y': REG (5, 16, CONTROL);
     case 'z': MAPPED_REG (0, 0, GP, reg_0_map);
+
+    case '=':
+      switch (p[1])
+	{
+	case 'h':  REG (5, 6,  MXU128);
+	case 'j':  REG (5, 11, MXU128);
+	case 'k':  SINT (15, 11);
+	case 'l':  SINT (10, 11);
+	case 'n':  UINT (6, 16);
+	case 's':  REG (5, 16, MXU128);
+	case 't':  REG (5, 21, MXU128);
+	case 'v':  SPECIAL (5, 16, IMM_INDEX);
+	case 'w':  SPECIAL (8, 16, IMM_INDEX);
+	case 'x':  REG (5, 6,  MXU128_CR);
+	case 'y':  UINT (8, 16);
+	case 'g':  BRANCH (10, 6, 2);
+	case 'L':  INT_ADJ (10, 11, 0x1ff, 4, false);
+	}
+      break;
     }
   return 0;
 }
@@ -429,6 +448,9 @@
